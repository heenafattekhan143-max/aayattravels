# ==============================================================================
# Purvi Travels — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to Git!
# ==============================================================================

# ── FRONTEND (Vite) ────────────────────────────────────────────────────────────
# Set this on Vercel's dashboard (Environment Variables section).
# In local development, leave it empty — the Vite proxy handles /api/* calls.
# In production, set it to your Render/Koyeb backend URL (no trailing slash).
VITE_API_URL=https://your-app-name.onrender.com

# ── BACKEND (FastAPI) ──────────────────────────────────────────────────────────
# Set these on Render's dashboard (Environment Variables section).

# MongoDB Atlas connection string (get this from Atlas → Connect → Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/purvi_travels?retryWrites=true&w=majority

# Secret key for JWT token signing. Use a long random string.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret-key

# CORS: comma-separated list of allowed frontend origins.
# Set to your Vercel URL after deployment.
ALLOWED_ORIGINS=https://your-app-name.vercel.app
